# FYDNE local/runtime configuration.
# Copy values to your server environment. Do not commit real secrets.

# Game <-> backend socket
FYDNE_API_TOKEN=
FYDNE_RECOVERY_MODE=1
FYDNE_SOCKET_ENABLED=1
FYDNE_SOCKET_IP=127.0.0.1
FYDNE_SOCKET_PORT=2467
FYDNE_SOCKET_HOST=0.0.0.0
FYDNE_SOCKET_DATA=
FYDNE_API_URL=
FYDNE_CDN_URL=

# Runtime diagnostics. Keep payload tracing off unless you are debugging locally:
# it can include nicknames, Steam IDs, user IDs, IPs or gameplay state.
FYDNE_TRACE_RECOVERY=1
FYDNE_TRACE_EVENTS=0
FYDNE_TRACE_EVERY_HANDLER=0
FYDNE_TRACE_SPAWN=1
FYDNE_TRACE_SOCKET=1
FYDNE_TRACE_SOCKET_PAYLOADS=0

# Steam Web API
FYDNE_STEAM_WEB_API_KEY=

# Discord webhooks. Empty means disabled.
FYDNE_WEBHOOK_BANS_PUBLIC=
FYDNE_WEBHOOK_BANS_PATROL=
FYDNE_WEBHOOK_BANS_ADMIN=
FYDNE_WEBHOOK_BANS_OWNERS=
FYDNE_WEBHOOK_ANTICHEAT=
FYDNE_WEBHOOK_MODERATION=
FYDNE_WEBHOOK_BUG_REPORT=
FYDNE_AI_MODERATION_WEBHOOK=

# Telegram alerts. Empty means disabled.
FYDNE_TELEGRAM_BOT_TOKEN=
FYDNE_TELEGRAM_CHAT_ID=

# Optional moderation integration.
FYDNE_AI_MODERATION_BASIC_AUTH=
