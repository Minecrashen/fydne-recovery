# Секреты — НИКОГДА не коммитить
*.key
*.pem
*.env
.env
secrets.*
config.local.*
*token*.txt

# Бинарники и зависимости (брать из легальной установки сервера, не хранить в git)
*.dll
*.nupkg
node_modules/
packages/
bin/
obj/

# Дампы БД (большие, не для git)
*.bson
*.dump
*.archive
dump/

# Рабочие каталоги (клонируются/собираются локально, не в git)
sources/          # клоны исходных репозиториев (clone-sources.ps1)
dependencies/     # игровые DLL (gather-dependencies.ps1)

# ОС / редакторы
Thumbs.db
.DS_Store
.vs/
.idea/
*.user
*.suo
